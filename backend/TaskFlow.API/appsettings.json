{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=task-flow;Username=taskflow;Password=Admin@123"
  },
  "Jwt": {
    "Issuer": "TaskFlow",
    "Audience": "TaskFlow",
    "SigningKey": "",
    "AccessTokenMinutes": 60
  },
  "Seed": {
    "AdminEmail": "",
    "AdminPassword": "",
    "DemoDataEnabled": false,
    "DemoOrganizationsCount": 12,
    "DemoUsersPerOrganization": 5,
    "DemoProjectsPerOrganization": 6,
    "DemoTasksPerProject": 8,
    "DemoUserPassword": "Demo123!"
  }
}
