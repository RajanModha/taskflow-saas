{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "Startup": {
    "RunDatabaseInitialization": true
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Issuer": "TaskFlow",
    "Audience": "TaskFlow",
    "SigningKey": "",
    "AccessTokenMinutes": 120,
    "RefreshTokenDays": 30
  },
  "Seed": {
    "AdminEmail": "",
    "AdminPassword": "",
    "DemoDataEnabled": true,
    "DemoOrganizationsCount": 12,
    "DemoUsersPerOrganization": 5,
    "DemoProjectsPerOrganization": 6,
    "DemoTasksPerProject": 8,
    "DemoUserPassword": ""
  }
}

