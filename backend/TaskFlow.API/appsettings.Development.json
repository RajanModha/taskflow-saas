{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=task-flow;Username=taskflow;Password=Admin@123"
  },
  "Jwt": {
    "Issuer": "TaskFlow",
    "Audience": "TaskFlow",
    "SigningKey": "Development_SigningKey_Min32Chars_ChangeInProduction!",
    "AccessTokenMinutes": 120
  },
  "Seed": {
    "AdminEmail": "admin@taskflow.local",
    "AdminPassword": "Admin123!"
  }
}
