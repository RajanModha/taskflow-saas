@TaskFlow.API_HostAddress = http://localhost:5005

### Info (anonymous)
GET {{TaskFlow.API_HostAddress}}/api/info
Accept: application/json

###

### Register
POST {{TaskFlow.API_HostAddress}}/api/auth/register
Content-Type: application/json

{
  "email": "user@example.com",
  "userName": "demo.user",
  "password": "Str0ng!Pass",
  "confirmPassword": "Str0ng!Pass",
  "organizationName": "Acme Workspace"
}

###

### Login
POST {{TaskFlow.API_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "user@example.com",
  "password": "Str0ng!Pass"
}

###

### Me (set @token from login/register response)
@token = paste_jwt_here

GET {{TaskFlow.API_HostAddress}}/api/auth/me
Authorization: Bearer {{token}}

###

### Projects (authenticated)
@token = paste_jwt_here

### List projects
GET {{TaskFlow.API_HostAddress}}/api/projects?page=1&pageSize=20&q=&sortBy=createdatutc&sortDir=desc
Authorization: Bearer {{token}}
Accept: application/json

### Create project
POST {{TaskFlow.API_HostAddress}}/api/projects
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Roadmap 2026",
  "description": "Quarterly planning"
}

### Get project by id
@projectId = paste_project_guid_here
GET {{TaskFlow.API_HostAddress}}/api/projects/{{projectId}}
Authorization: Bearer {{token}}
Accept: application/json

### Update project
PUT {{TaskFlow.API_HostAddress}}/api/projects/{{projectId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Roadmap 2026 (updated)",
  "description": "Quarterly planning (updated)"
}

### Delete project
DELETE {{TaskFlow.API_HostAddress}}/api/projects/{{projectId}}
Authorization: Bearer {{token}}

###

### Tasks (authenticated)
### List tasks for a project
@projectId = paste_project_guid_here
GET {{TaskFlow.API_HostAddress}}/api/tasks?page=1&pageSize=20&projectId={{projectId}}&status=&priority=&q=&sortBy=createdatutc&sortDir=desc
Authorization: Bearer {{token}}
Accept: application/json

### Create task
POST {{TaskFlow.API_HostAddress}}/api/tasks
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "projectId": "{{projectId}}",
  "title": "Define Q2 scope",
  "description": "Decide milestones and owners",
  "status": 1,
  "priority": 2,
  "dueDateUtc": "2026-04-10T00:00:00Z"
}

### Get task by id
@taskId = paste_task_guid_here
GET {{TaskFlow.API_HostAddress}}/api/tasks/{{taskId}}
Authorization: Bearer {{token}}
Accept: application/json

### Update task
PUT {{TaskFlow.API_HostAddress}}/api/tasks/{{taskId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "Define Q2 scope (updated)",
  "description": "Decide milestones and owners (updated)",
  "status": 2,
  "priority": 3,
  "dueDateUtc": "2026-04-18T00:00:00Z"
}

### Delete task
DELETE {{TaskFlow.API_HostAddress}}/api/tasks/{{taskId}}
Authorization: Bearer {{token}}

###

### Dashboard analytics
GET {{TaskFlow.API_HostAddress}}/api/dashboard/stats
Authorization: Bearer {{token}}
Accept: application/json

###

### Create Workspace (returns a new JWT)
POST {{TaskFlow.API_HostAddress}}/api/workspaces
Content-Type: application/json

{
  "name": "New Workspace"
}

### Note:
### This endpoint returns a fresh JWT (with new org_id). Copy it and update @token below.
@token = paste_new_jwt_here

### Join Workspace (switch org using join code)
POST {{TaskFlow.API_HostAddress}}/api/workspaces/join
Content-Type: application/json

{
  "code": "PASTE_JOIN_CODE"
}

### After join, copy returned JWT and call /api/auth/me again.
@token = paste_new_jwt_here_after_join

GET {{TaskFlow.API_HostAddress}}/api/auth/me
Authorization: Bearer {{token}}

###
